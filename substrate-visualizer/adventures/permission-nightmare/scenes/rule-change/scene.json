{
  "id": "rule-change",
  "title": "The Hard Change",
  "description": "PM requests a structural change - renaming the ownership field",
  "category": "planning",
  "version": 1,
  "stage": {
    "width": 960,
    "height": 540,
    "background": "#fff3cd"
  },
  "entities": {
    "pm": {
      "type": "stickActor",
      "x": 80,
      "y": 340,
      "scale": 1,
      "head": "😊",
      "name": "Product Manager"
    },
    "dev": {
      "type": "stickActor",
      "x": 750,
      "y": 340,
      "scale": 1,
      "head": "😀",
      "name": "Developer"
    },
    "whiteboard": {
      "type": "whiteboard",
      "x": 154,
      "y": 39,
      "width": 500,
      "height": 280,
      "initialText": "6 MONTHS LATER..."
    }
  },
  "timeline": [
    {
      "do": "fadeIn",
      "args": {
        "duration": 0.5
      }
    },
    {
      "do": "pose",
      "target": "pm",
      "args": {
        "name": "pointRight",
        "duration": 0.1
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "handsDown",
        "duration": 0.1
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "We're migrating to a new identity system!",
        "hold": 2
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "🤨"
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "What does that mean for permissions?",
        "hold": 1.5
      }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": {
        "text": "\n\nRENAME REQUIRED:\nowner_email → owner_principal",
        "speedCps": 50
      }
    },
    {
      "do": "pose",
      "target": "pm",
      "args": {
        "name": "pointUp",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "Emails are out. Principal IDs are in.",
        "hold": 2.5
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "😱"
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "thinkingChin",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "That's not just adding a clause... that's a RENAME.",
        "hold": 2.5
      }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": {
        "text": "\n\nIMPACT:\n- 4 codebases\n- 12+ query files\n- Find/replace won't catch semantics\n- Different ORMs, different syntax",
        "speedCps": 40
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "It's just a rename. How hard can it be?",
        "hold": 2
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "😤"
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "shrug",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "owner_email, ownerEmail, OwnerEmail, owner-email... every system is different.",
        "hold": 3
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1
      }
    }
  ]
}

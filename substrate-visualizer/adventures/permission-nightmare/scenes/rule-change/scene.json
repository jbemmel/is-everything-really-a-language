{
  "id": "rule-change",
  "title": "The Rule Change",
  "description": "PM requests a change to the permission rules",
  "category": "planning",
  "version": 1,
  "stage": {
    "width": 960,
    "height": 540,
    "background": "#fff3cd"
  },
  "entities": {
    "pm": {
      "type": "stickActor",
      "x": 80,
      "y": 340,
      "scale": 1,
      "head": "😊",
      "name": "Product Manager"
    },
    "dev": {
      "type": "stickActor",
      "x": 750,
      "y": 340,
      "scale": 1,
      "head": "😀",
      "name": "Developer"
    },
    "whiteboard": {
      "type": "whiteboard",
      "x": 154,
      "y": 39,
      "width": 500,
      "height": 280,
      "initialText": "3 MONTHS LATER..."
    }
  },
  "timeline": [
    {
      "do": "fadeIn",
      "args": {
        "duration": 0.5
      }
    },
    {
      "do": "pose",
      "target": "pm",
      "args": {
        "name": "pointRight",
        "duration": 0.1
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "handsDown",
        "duration": 0.1
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "Great news! We need a small change...",
        "hold": 2
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "🤨"
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "What kind of change?",
        "hold": 1.5
      }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": {
        "text": "\n\nNEW REQUIREMENT:\nAdmins should see ALL projects!",
        "speedCps": 50
      }
    },
    {
      "do": "pose",
      "target": "pm",
      "args": {
        "name": "pointUp",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "If user.is_admin = true, they see everything!",
        "hold": 2.5
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "😱"
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "thinkingChin",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "That means updating... 4 codebases, 12 files...",
        "hold": 2.5
      }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": {
        "text": "\n\nOLD: owner_email = user.email OR team_member\nNEW: is_admin OR owner_email = user.email OR team_member",
        "speedCps": 40
      }
    },
    {
      "do": "bubbleSay",
      "target": "pm",
      "args": {
        "text": "Should be quick, right? Just add an OR clause!",
        "hold": 2
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "😤"
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "shrug",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "In 4 different languages, with 4 different ORMs...",
        "hold": 2.5
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1
      }
    }
  ]
}

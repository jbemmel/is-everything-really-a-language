{
  "id": "erb-solution",
  "title": "The ERB Solution",
  "description": "Developer shows how ERB handles the rename with a single semantic change",
  "category": "solution",
  "version": 1,
  "stage": {
    "width": 960,
    "height": 540,
    "background": "#d4edda"
  },
  "entities": {
    "dev": {
      "type": "stickActor",
      "x": 50,
      "y": 420,
      "scale": 0.8,
      "head": "😊",
      "name": "Developer"
    },
    "editor1": {
      "type": "codeEditor",
      "x": 150,
      "y": 20,
      "width": 380,
      "height": 160,
      "name": "Before (Policy)"
    },
    "editor2": {
      "type": "codeEditor",
      "x": 550,
      "y": 20,
      "width": 380,
      "height": 160,
      "name": "After (Policy)"
    },
    "editor3": {
      "type": "codeEditor",
      "x": 150,
      "y": 200,
      "width": 780,
      "height": 100,
      "name": "Terminal"
    },
    "chat": {
      "type": "chatPanel",
      "x": 150,
      "y": 320,
      "width": 780,
      "height": 200
    }
  },
  "timeline": [
    {
      "do": "fadeIn",
      "args": {
        "duration": 0.5
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "presentRight",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "Now let's see ERB handle that same rename.",
        "hold": 2
      }
    },
    {
      "do": "typeCode",
      "target": "editor1",
      "args": {
        "text": "// can_see_project (OLD)\n\nproject.owner_email\n  = current_user.email",
        "speedCps": 80
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1
      }
    },
    {
      "do": "typeCode",
      "target": "editor2",
      "args": {
        "text": "// can_see_project (NEW)\n\nproject.owner_principal\n  = current_user.id",
        "speedCps": 80
      }
    },
    {
      "do": "chatSay",
      "target": "chat",
      "args": {
        "speaker": "Developer",
        "text": "One semantic change. owner_email → owner_principal, email → id."
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 2
      }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": {
        "name": "pointUp",
        "duration": 0.3
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "Now I regenerate all substrates...",
        "hold": 2
      }
    },
    {
      "do": "typeCode",
      "target": "editor3",
      "args": {
        "text": "$ erb generate --all\n\n✓ node-api/permissions.js     (owner_email → owner_principal)\n✓ python-backend/perms.py     (owner_email → owner_principal)\n✓ sql-views/can_see.sql       (owner_email → owner_principal)\n✓ swift-mobile/Permissions.swift (ownerEmail → ownerPrincipal)",
        "speedCps": 100
      }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": {
        "emoji": "😃"
      }
    },
    {
      "do": "chatSay",
      "target": "chat",
      "args": {
        "speaker": "Developer",
        "text": "Each substrate gets the right naming convention. snake_case, camelCase, PascalCase - all handled."
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 2.5
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "Legacy: 2+ days of find/replace across systems.",
        "hold": 2
      }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": {
        "text": "ERB: 5 minutes. One edit. Regenerate.",
        "hold": 2.5
      }
    },
    {
      "do": "chatSay",
      "target": "chat",
      "args": {
        "speaker": "Developer",
        "text": "But we're not done yet. We still need to PROVE it works..."
      }
    },
    {
      "do": "wait",
      "args": {
        "duration": 1.5
      }
    }
  ]
}

{
  "id": "pain-conclusion",
  "title": "The Punchline",
  "description": "The realization of wasted time and risk",
  "category": "conclusion",
  "version": 1,
  "stage": {
    "width": 960,
    "height": 540,
    "background": "#fff8e1"
  },
  "entities": {
    "dev": {
      "type": "stickActor",
      "x": 100,
      "y": 340,
      "scale": 1,
      "head": "😫",
      "name": "Developer"
    },
    "cto": {
      "type": "stickActor",
      "x": 700,
      "y": 340,
      "scale": 1,
      "head": "🤔",
      "name": "CTO"
    },
    "whiteboard": {
      "type": "whiteboard",
      "x": 200,
      "y": 20,
      "width": 560,
      "height": 290,
      "initialText": ""
    }
  },
  "timeline": [
    {
      "do": "fadeIn",
      "args": { "duration": 0.5 }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": { "text": "THE PAIN SCORECARD", "speedCps": 60 }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": { "name": "handsDown", "duration": 0.3 }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": { "text": "Let me show you what just happened...", "hold": 2 }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": { "text": "\n\nInitial Implementation:  2 hours\nRule Change Update:      2 hours\n----------------------------\nTotal Time:              4 hours", "speedCps": 50 }
    },
    {
      "do": "setHead",
      "target": "cto",
      "args": { "emoji": "😬" }
    },
    {
      "do": "bubbleSay",
      "target": "cto",
      "args": { "text": "4 hours for ONE simple rule?", "hold": 2 }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": { "name": "pointUp", "duration": 0.3 }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": { "text": "And it gets worse...", "hold": 1.5 }
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": { "text": "\n\nSystems updated:         4\nPlaces rule exists:      4\nChance one got missed:   HIGH", "speedCps": 50 }
    },
    {
      "do": "setHead",
      "target": "cto",
      "args": { "emoji": "😰" }
    },
    {
      "do": "bubbleSay",
      "target": "cto",
      "args": { "text": "What if the rule changes again?", "hold": 2 }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": { "emoji": "💀" }
    },
    {
      "do": "pose",
      "target": "dev",
      "args": { "name": "shrug", "duration": 0.3 }
    },
    {
      "do": "bubbleSay",
      "target": "dev",
      "args": { "text": "Another 2 hours. Every. Single. Time.", "hold": 2.5 }
    },
    {
      "do": "clearBoard",
      "target": "whiteboard",
      "args": {}
    },
    {
      "do": "writeBoard",
      "target": "whiteboard",
      "args": { "text": "THE REAL PROBLEM:\n\nSame rule, defined 4 times\n= 4x the maintenance\n= 4x the risk\n= 4x the cost\n\nThere has to be a better way...", "speedCps": 40 }
    },
    {
      "do": "setHead",
      "target": "cto",
      "args": { "emoji": "💡" }
    },
    {
      "do": "pose",
      "target": "cto",
      "args": { "name": "pointUp", "duration": 0.3 }
    },
    {
      "do": "bubbleSay",
      "target": "cto",
      "args": { "text": "What if we only defined it ONCE?", "hold": 3 }
    },
    {
      "do": "setHead",
      "target": "dev",
      "args": { "emoji": "🤯" }
    },
    {
      "do": "wait",
      "args": { "duration": 2 }
    }
  ]
}
